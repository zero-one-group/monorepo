        "@strapi/upload": "5.40.0",
        "consola": "^3.4.2",
        "dotenv": "^17.3.1",
        "pg": "^8.20.0",
        "react": "~18.3.1",
        "react-dom": "~18.3.1",
        "react-router-dom": "~6.29.0",
