# Generated by `go-modular generate-config`
# Edit to taste; the defaults are safe for local dev.

# ----- App -----
APP_MODE=development
APP_BASE_URL=http://localhost:8000
JWT_SECRET_KEY=_THIS_IS_DEFAULT_JWT_SECRET_KEY_
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=*
CORS_MAX_AGE=300
CORS_CREDENTIALS=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_BURST_SIZE=60
ENABLE_API_DOCS=true

# ----- Database -----
DATABASE_URL=postgresql://postgres:securedb@localhost:5432/postgres?sslmode=disable
PG_MAX_POOL_SIZE=10
PG_MAX_RETRIES=5

# ----- Mailer (lettre STARTTLS on 587, implicit TLS on 465) -----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_NAME=System Mailer
SMTP_SENDER_EMAIL=mailer@example.com

# ----- FileStore (S3-compatible; unused by auth/user) -----
PUBLIC_ASSETS_URL=http://localhost:8010
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=s3admin
S3_SECRET_KEY=s3passw0rd
S3_BUCKET_NAME=devbucket
S3_REGION=auto
S3_FORCE_PATH_STYLE=false
S3_USE_SSL=false

# ----- Logging -----
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_NO_COLOR=false

# ----- OpenTelemetry -----
OTEL_SERVICE_NAME=go-modular
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=authorization=YOUR_INGESTION_API_KEY
OTEL_ENABLE_TELEMETRY=false
OTEL_INSECURE_MODE=false
OTEL_TRACING_SAMPLE_RATE=0.7
