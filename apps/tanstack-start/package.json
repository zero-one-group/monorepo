{
    "name": "tanstack-start",
    "private": true,
    "description": "_CHANGE_ME_DESCRIPTION_",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "start": "node .output/server/index.mjs",
        "cleanup": "pnpm dlx del-cli node_modules .output .vinxi dist tests-results",
        "update-deps": "npm-check-updates --configFileName .ncurc.json",
        "test-report": "pnpm dlx serve tests-results -l 9000 -s -n -C",
        "test-coverage": "pnpm run typegen && vitest run --coverage",
        "test-ui": "pnpm run typegen && vitest --ui",
        "test": "pnpm run typegen && vitest --run",
        "lint": "oxlint --fix .",
        "check": "oxlint --fix . && oxfmt .",
        "e2e-install": "playwright install --with-deps",
        "e2e-chrome": "playwright test --headed --project Chromium",
        "e2e-firefox": "playwright test --headed --project Firefox",
        "e2e-mobile": "playwright test --headed --project 'Mobile Chrome'",
        "e2e-safari": "playwright test --headed --project Safari",
        "e2e-report": "playwright show-report tests-results/e2e-html",
        "e2e-ui": "playwright test --ui",
        "e2e": "playwright test",
        "typegen": "tsr generate",
        "typecheck": "pnpm run typegen && tsc --noEmit"
    },
    "dependencies": {
        "@repo/shared-ui": "workspace:*",
        "@tanstack/react-router": "1.168.3",
        "@tanstack/react-router-devtools": "1.166.11",
        "@tanstack/react-start": "1.167.6",
        "consola": "^3.4.2",
        "lucide-react": "^1.6.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "std-env": "^4.0.0",
        "tailwind-variants": "^3.2.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/router-cli": "1.166.18",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.1",
        "@vitest/ui": "^4.1.1",
        "dotenv": "^17.3.1",
        "happy-dom": "^20.8.8",
        "nitro": "3.0.260311-beta",
        "npm-check-updates": "catalog:",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "playwright": "^1.58.2",
        "tailwindcss": "^4.2.2",
        "tailwindcss-motion": "^1.1.1",
        "typescript": "catalog:",
        "vite": "~8.0.2",
        "vite-plugin-devtools-json": "^1.0.0",
        "vitest": "^4.1.1"
    }
}
