{
  "name": "{{ package_name | kebab_case }}",
  "description": "{{ package_description }}",
  "private": true,
  "scripts": {
    "dev": "strapi develop",
    "build": "strapi build --stats",
    "start": "NODE_ENV=production strapi start",
    "start-node": "NODE_ENV=production node --no-warnings -r dotenv/config server.cjs",
    "cleanup": "pnpm dlx del-cli node_modules build dist .{cache,data,strapi,tmp} _data",
    "update-deps": "npm-check-updates --configFileName .ncurc.json",
		"lint": "oxlint --fix .",
		"check": "oxlint --fix . && oxfmt .",
    "typecheck": "tsc --noEmit",
    "strapi": "strapi"
  },
  "dependencies": {
    "@strapi/plugin-documentation": "5.40.0",
    "@strapi/plugin-users-permissions": "5.40.0",
    "@strapi/provider-email-nodemailer": "5.40.0",
    "@strapi/provider-upload-aws-s3": "5.40.0",
    "@strapi/strapi": "5.40.0",
    "@strapi/upload": "5.40.0",
    "consola": "^3.4.2",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "react-dom": "~18.3.1",
    "react-router-dom": "~6.29.0",
    "react": "~18.3.1",
    "sharp": "^0.34.5",
    "std-env": "^4.0.0",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
    "@strapi/typescript-utils": "5.40.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react-dom": "~18.3.1",
    "@types/react": "~18.3.1",
    "npm-check-updates": "^19.6.5",
    "typescript": "catalog:",
    "vite": "~6.3.5"
  },
  "strapi": {}
}
