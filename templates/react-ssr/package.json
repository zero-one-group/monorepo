{
  "name": "{{ package_name | kebab_case }}",
  "description": "{{ package_description }}",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "NODE_ENV=development node -r dotenv/config server.mjs",
    "start": "node --no-warnings -r dotenv/config server.mjs",
    "cleanup": "pnpm dlx del-cli node_modules build .react-router tests-results",
    "update-deps": "npm-check-updates --configFileName .ncurc.json",
    "test-report": "pnpm dlx serve tests-results -l 9000 -s -n -C",
    "test-coverage": "vitest run --coverage",
    "test-ui": "vitest --ui",
    "test": "vitest --run",
		"lint": "oxlint --fix .",
		"check": "oxlint --fix . && oxfmt .",
    "e2e-install": "playwright install --with-deps",
    "e2e-chrome": "playwright test --headed --project Chromium",
    "e2e-firefox": "playwright test --headed --project Firefox",
    "e2e-mobile": "playwright test --headed --project 'Mobile Chrome'",
    "e2e-safari": "playwright test --headed --project Safari",
    "e2e-report": "playwright show-report tests-results/e2e-html",
    "e2e-ui": "playwright test --ui",
    "e2e": "playwright test",
    "typegen": "react-router typegen",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-router/express": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "compression": "^1.8.1",
    "consola": "^3.4.2",
    "express-rate-limit": "^8.3.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "isbot": "^5",
    "lucide-react": "^1.7.0",
    "morgan": "^1.10.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "react-router": "^7.13.2",
    "react": "^19.2.4",
    "std-env": "^4.0.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "dotenv": "^17.4.0",
    "happy-dom": "^20.8.9",
    "npm-check-updates": "catalog:",
    "playwright": "^1.59.1",
    "react-router-devtools": "^6.2.0",
    "tailwindcss-motion": "^1.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "~8.0.3",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.2"
  }
}
