{
	"name": "@repo/{{ package_name | kebab_case }}",
	"private": true,
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		"./components": "./src/components/index.ts",
		"./hooks": "./src/hooks/index.ts",
		"./theme": "./src/theme.tsx",
		"./utils": "./src/utils.ts"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "NODE_ENV=production vite build",
		"storybook": "storybook dev -p 6006 --no-open",
		"storybook-build": "storybook build -o storybook-static",
		"cleanup": "pnpm dlx del-cli dist node_modules pnpm-lock.yaml storybook-static",
		"start": "pnpm dlx local-web-server -p 6006 -d storybook-static",
		"update-deps": "npm-check-updates --configFileName .ncurc.json",
		"prepublishOnly": "pnpm run build:vite",
		"lint": "oxlint --fix .",
		"check": "oxlint --fix . && oxfmt .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@nanostores/persistent": "^1.3.3",
		"@nanostores/react": "^1.1.0",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.6.0",
		"nanostores": "^1.2.0",
		"radix-ui": "^1.4.3",
		"react-day-picker": "^9.14.0",
		"react-hook-form": "^7.72.0",
		"react-resizable-panels": "^3.0.6",
		"recharts": "^3.8.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"@hookform/resolvers": "^5.2.2",
		"@storybook/addon-a11y": "10.3.3",
		"@storybook/addon-links": "10.3.3",
		"@storybook/addon-themes": "10.3.3",
		"@storybook/react-vite": "10.3.3",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"consola": "^3.4.2",
		"npm-check-updates": "catalog:",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"std-env": "^4.0.0",
		"storybook": "10.3.3",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tailwindcss-motion": "^1.1.1",
		"typescript": "catalog:",
		"vite": "~8.0.3",
		"vite-plugin-dts": "^4.5.4",
		"@storybook/addon-docs": "10.3.3"
	},
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	}
}
