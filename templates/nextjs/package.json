{
  "name": "{{ package_name | kebab_case }}",
  "description": "{{ package_description }}",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
		"check": "oxfmt .",
    "cleanup": "pnpm dlx del-cli node_modules .{cache,data,next,tmp} dist tests-results",
    "update-deps": "npm-check-updates --configFileName .ncurc.json",
    "test-report": "pnpm dlx serve tests-results -l 9000 -s -n -C",
    "test-coverage": "vitest run --coverage",
    "test-ui": "vitest --ui",
    "test": "vitest --run",
    "e2e-install": "playwright install --with-deps",
    "e2e-chrome": "playwright test --headed --project Chromium",
    "e2e-firefox": "playwright test --headed --project Firefox",
    "e2e-mobile": "playwright test --headed --project 'Mobile Chrome'",
    "e2e-safari": "playwright test --headed --project Safari",
    "e2e-report": "playwright show-report tests-results/e2e-html",
    "e2e-ui": "playwright test --ui",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "std-env": "^4.0.0"
  },
  "devDependencies": {
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "eslint-config-next": "16.2.1",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.8",
    "npm-check-updates": "catalog:",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-motion": "^1.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vitest": "^4.1.1"
  }
}
